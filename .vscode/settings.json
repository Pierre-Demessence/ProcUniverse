{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "eslint.useFlatConfig": true,
  "files.eol": "\n",
  "files.exclude": {
    "coverage/": true,
    "dist/": true,
    "node_modules/": true
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib"
}
