{
  "name": "procuniverse",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Procedurally generated 2D universe explorer built on @pierre/ecs.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@pierre/ecs": "file:../Entity-Cornponent-System-Engine",
    "@preact/signals": "^2.9.1",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@preact/preset-vite": "^2.10.5",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.2"
  }
}
